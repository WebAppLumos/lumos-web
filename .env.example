# ── Lumos Web 로컬/배포 환경 변수 ──
# cp .env.example .env 후 값을 채워 사용하세요.

# 백엔드 API (로컬: localhost, Vercel: Render API URL)
VITE_API_BASE_URL=http://localhost:8080

# Firebase (클라이언트 SDK — Firebase 콘솔 > 프로젝트 설정)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# 카카오맵 JavaScript 키 (Kakao Developers > 앱 > JavaScript 키, Web 도메인 등록)
VITE_KAKAO_MAP_APP_KEY=your-kakao-javascript-key

# 카카오 모빌리티 길찾기 REST API 키 (Vite dev server 프록시 전용, VITE_ 접두사 금지)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# EDWARD Chrome 확장 프로그램 ID (선택)
# VITE_LUMOS_EXTENSION_ID=your-chrome-extension-id
